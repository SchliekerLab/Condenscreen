pwalk(cache_df, ~ assign(..1, ..2, envir = smiles_cache))
}
}
cache_get   <- function(key) if (exists(key, smiles_cache, inherits = FALSE)) get(key, smiles_cache) else NULL
cache_set   <- function(key, value) assign(key, value, smiles_cache)
cache_flush <- function() {
keys <- ls(smiles_cache, all.names = TRUE)
if (length(keys) > 0) {
tibble(
key   = keys,
value = vapply(keys, function(k) get(k, smiles_cache), character(1))
) %>% write_tsv(CACHE_PATH)
}
}
# ============================================================
# 3) SMILES retrieval helpers (UNCHANGED LOGIC)
# ============================================================
HIGH_RISK_METALS <- c("HG", "PB", "CD", "AS", "CR")
MODERATE_METALS  <- c("ZN", "CU", "FE", "NI", "CO", "MN")
strip_metals <- function(smiles) {
if (is.na(smiles) || !nzchar(smiles)) return(NA_character_)
if (grepl("PYRITHIONE", smiles, ignore.case = TRUE) ||
grepl("\\[Zn\\+\\+\\].*c1cccc\\[n\\+\\]1\\[O-\\]", smiles)) {
return("[S-]c1cccc[n+]1[O-]")
}
if (grepl("\\[(Zn|Hg|Cu|Fe|Ni|Co)", smiles, ignore.case = TRUE)) {
return(NA_character_)
}
smiles
}
detect_high_risk_metals <- function(smiles) {
if (is.na(smiles) || !nzchar(smiles)) {
return(list(contains = FALSE, metals = NA_character_))
}
metal_pattern <- "\\[(Zn|Hg|Pb|Cd|As|Cr|Ni|Co|Cu|Mn|Fe|Sn|Sb)"
hits <- unique(toupper(regmatches(
smiles, gregexpr(metal_pattern, smiles, ignore.case = TRUE)
)[[1]]))
if (length(hits) == 0) {
return(list(contains = FALSE, metals = NA_character_))
}
list(
contains = TRUE,
metals   = paste(gsub("\\[", "", hits), collapse = ",")
)
}
metal_risk_from_types <- function(metal_types) {
if (is.na(metal_types) || !nzchar(metal_types)) return(NA_character_)
metals <- trimws(toupper(unlist(strsplit(metal_types, ","))))
if (any(metals %in% HIGH_RISK_METALS)) return("HIGH")
if (any(metals %in% MODERATE_METALS))  return("MODERATE")
NA_character_
}
clean_cas <- function(x) {
if (is.na(x) || !nzchar(trimws(x))) return(NA_character_)
x <- gsub("\\[.*?\\]", "", x)
parts <- trimws(unlist(strsplit(x, "[,;]")))
parts <- parts[nzchar(parts)]
if (length(parts) == 0) return(NA_character_)
cas <- parts[grepl("^\\d{2,7}-\\d{2}-\\d$", parts)]
if (length(cas)) cas[1] else parts[1]
}
# --- PubChem / CACTUS unchanged ---
pubchem_smiles <- function(id, namespace = c("name", "rn"), timeout_s = 20) {
namespace <- match.arg(namespace)
if (is.na(id) || !nzchar(trimws(id))) return(NA_character_)
url <- sprintf(
"https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/%s/%s/property/IsomericSMILES,CanonicalSMILES/JSON",
namespace, URLencode(id, reserved = TRUE)
)
resp <- tryCatch(request(url) |> req_timeout(timeout_s) |> req_perform(),
error = function(e) NULL)
if (is.null(resp) || resp_status(resp) >= 400) return(NA_character_)
j <- tryCatch(fromJSON(resp_body_string(resp)), error = function(e) NULL)
props <- j$PropertyTable$Properties
if (is.null(props) || nrow(props) == 0) return(NA_character_)
smi <- props$IsomericSMILES[1]
if (is.na(smi) || !isTRUE(isTRUE(nzchar(smi)))) smi <- props$CanonicalSMILES[1]
if (is.na(smi) || !isTRUE(isTRUE(nzchar(smi)))) NA_character_ else smi
}
cactus_smiles <- function(id, timeout_s = 20) {
if (is.na(id) || !nzchar(trimws(id))) return(NA_character_)
url <- sprintf(
"https://cactus.nci.nih.gov/chemical/structure/%s/smiles",
URLencode(id, reserved = TRUE)
)
for (k in 1:3) {
resp <- tryCatch(request(url) |> req_timeout(timeout_s) |> req_perform(),
error = function(e) NULL)
if (!is.null(resp) && resp_status(resp) < 400) {
smi <- trimws(resp_body_string(resp))
if (isTRUE(nzchar(smi)) && !grepl("not found", smi, ignore.case = TRUE)) return(smi)
}
Sys.sleep(0.5 * k)
}
NA_character_
}
get_smiles <- function(cas, name) {
cas1  <- clean_cas(cas)
name1 <- if (is.na(name) || !nzchar(trimws(name))) NA_character_ else trimws(name)
for (key in c(
if (!is.na(cas1)) paste0("RN:", cas1),
if (!is.na(name1)) paste0("NM:", name1)
)) {
cached <- cache_get(key)
if (!is.null(cached)) {
if (length(cached) == 1 && !is.na(cached) && nzchar(cached)) {
return(as.character(cached))
} else {
return(NA_character_)
}
}
}
smi <- NA_character_
if (!is.na(cas1))  smi <- pubchem_smiles(cas1, "rn")
if (is.na(smi) && !is.na(name1)) smi <- pubchem_smiles(name1, "name")
if (is.na(smi) && !is.na(cas1))  smi <- cactus_smiles(cas1)
if (is.na(smi) && !is.na(name1)) smi <- cactus_smiles(name1)
if (!is.na(cas1))  cache_set(paste0("RN:", cas1), smi)
if (!is.na(name1)) cache_set(paste0("NM:", name1), smi)
# SAFE return
if (length(smi) != 1) return(NA_character_)
if (is.na(smi))       return(NA_character_)
if (!isTRUE(isTRUE(nzchar(smi))))     return(NA_character_)
smi
}
# ============================================================
# 4) Retrieve SMILES
# ============================================================
df_hits <- df %>%
mutate(
CAS       = na_if(trimws(as.character(CAS)), ""),
Reference = na_if(trimws(as.character(Reference)), ""),
SMILES    = map2_chr(CAS, Reference, get_smiles),
SMILES_raw = SMILES
) %>%
mutate(
SMILES_stripped = vapply(SMILES, strip_metals, character(1))
) %>%
rowwise() %>%
mutate(
metal_info     = list(detect_high_risk_metals(SMILES_raw)),
Contains_Metal = metal_info$contains,
Metal_Types    = metal_info$metals
) %>%
ungroup() %>%
select(-metal_info)
df_final_hits <- df_final %>%
semi_join(
df %>% select(Plate, Well),
by = c("Plate", "Well")
)
# ============================================================
# 5) RDKit setup
# ============================================================
use_condaenv("rdkit-env", required = TRUE)
Chem     <- import("rdkit.Chem")
RDLogger <- import("rdkit.RDLogger")
RDLogger$DisableLog("rdApp.*")
Desc     <- import("rdkit.Chem.Descriptors")
Crip     <- import("rdkit.Chem.Crippen")
Lip      <- import("rdkit.Chem.Lipinski")
rdMS     <- import("rdkit.Chem.MolStandardize.rdMolStandardize")
uncharger     <- rdMS$Uncharger()
largest_frag  <- rdMS$LargestFragmentChooser()
safe_mol <- function(smi) {
if (is.na(smi) || !nzchar(trimws(smi))) return(NULL)
tryCatch(Chem$MolFromSmiles(trimws(smi)), error = function(e) NULL)
}
canonicalize_parent <- function(smiles) {
mol <- safe_mol(smiles)
if (is.null(mol)) return(NA_character_)
mol <- tryCatch(uncharger$uncharge(mol), error = function(e) mol)
mol <- tryCatch(largest_frag$choose(mol), error = function(e) mol)
Chem$MolToSmiles(mol, canonical = TRUE)
}
df_hits <- df_hits %>%
mutate(SMILES_used = vapply(SMILES_stripped, canonicalize_parent, character(1)))
# ============================================================
# 6) Alerts + Lipinski (UNCHANGED)
# ============================================================
# get_alerts()
# flag_molecule()
# calc_lipinski()
compiled_sets <- get_alerts()
unique_smiles <- df_hits %>%
filter(!is.na(SMILES_used), nzchar(SMILES_used)) %>%
distinct(SMILES_used)
properties_tbl <- tibble(SMILES_used = unique_smiles$SMILES_used) %>%
mutate(alert_flags = vapply(SMILES_used, flag_molecule, character(1),
compiled_sets = compiled_sets)) %>%
rowwise() %>%
mutate(props = list(calc_lipinski(SMILES_used))) %>%
ungroup() %>%
unnest(props)
# ============================================================
# 7) Final annotation
# ============================================================
df_final <- df_hits %>%
left_join(properties_tbl, by = "SMILES_used") %>%
mutate(
Viability = if ("Viability" %in% names(.)) Viability else 10,
has_smiles = !is.na(SMILES_used) & nzchar(SMILES_used),
flags = if_else(has_smiles, coalesce(alert_flags, ""), ""),
PAINS_NIH_Flagged = grepl("PAINS|MLSMR|NIH", flags, ignore.case = TRUE),
Industry_Flagged  = grepl("BMS|GLAXO|GSK|LINT|DUNDEE", flags, ignore.case = TRUE),
Other_Flagged     = grepl("INPHARMATICA|SURECHEMBL", flags, ignore.case = TRUE),
AlertScore = PAINS_NIH_Flagged * 6L +
Industry_Flagged  * 3L +
Other_Flagged     * 1L,
Cytotoxic = Viability <= -25,
flags = case_when(
has_smiles & Cytotoxic & nzchar(flags) ~ paste0("Cytotoxic | ", flags),
has_smiles & Cytotoxic                ~ "Cytotoxic",
TRUE                                  ~ flags
),
Risk = case_when(
!has_smiles          ~ "UNKNOWN",
Cytotoxic            ~ "HIGH",
AlertScore >= 5      ~ "HIGH",
AlertScore >= 3      ~ "MODERATE",
AlertScore >= 1      ~ "MILD",
TRUE                 ~ "CLEAN"
)
) %>%
mutate(Metal_Risk = vapply(Metal_Types, metal_risk_from_types, character(1))) %>%
select(-alert_flags, -has_smiles) %>%
as_tibble()
cache_flush()
overwrite_hits_qc <- function(wb_path, df_final) {
sheets <- openxlsx::getSheetNames(wb_path)
wb_list <- lapply(sheets, function(s) {
openxlsx::read.xlsx(wb_path, sheet = s)
})
names(wb_list) <- sheets
wb_list$Hits_QC <- as.data.frame(df_final)
writexl::write_xlsx(wb_list, wb_path)
}
overwrite_hits_qc(WB_MAIN, df_final)
overwrite_hits_qc(WB_QC,   df_final)
# ============================================================
# 8) Write back to BOTH Excel workbooks (FIXED)
# ============================================================
chem_annot_cols <- c(
"Risk","AlertScore","flags","Cytotoxic","MW","LogP","HBD","HBA",
"Lipinski","Lipinski_Failed","PAINS_NIH_Flagged",
"Industry_Flagged","Other_Flagged",
"SMILES_raw","SMILES_used",
"Contains_Metal","Metal_Types"
)
library(openxlsx)
export_hits <- function(wb_path, sheet = "Hits_QC", df) {
wb <- loadWorkbook(wb_path)
if (sheet %in% names(wb)) {
removeWorksheet(wb, sheet)
}
addWorksheet(wb, sheet)
writeData(
wb,
sheet,
df %>% mutate(across(where(is.factor), as.character))
)
freezePane(wb, sheet, firstRow = TRUE)
addFilter(wb, sheet, rows = 1, cols = 1:ncol(df))
saveWorkbook(wb, wb_path, overwrite = TRUE)
}
export_hits(WB_MAIN, "Hits_QC", df_final_hits)
export_hits(WB_QC,   "Hits_QC", df_final_hits)
message("✓ Chemistry annotation complete and written to both workbooks.")
